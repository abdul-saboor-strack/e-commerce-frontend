const LEGACY_THEME_MAP: Record<string, string> = {
    "midnight-noir": "black",
    "modern-slate": "black",
    "royal-purple": "black",
    "forest-luxe": "light",
    "coastal-calm": "light",
    "sunset-glow": "light",
};

const AppearanceSettings = () => {
    const navigate = useNavigate();
    const [s, setS] = useState<Settings>(DEFAULTS);
    const [saved, setSaved] = useState(false);
    const [loading, setLoading] = useState(true);
    const [selectedTheme, setSelectedTheme] = useState<string>("");

    useEffect(() => {
        (async () => {
            try {
                const res = await API.get("/settings");
                const merged: any = { ...DEFAULTS, ...(res.data || {}) };
                setS(merged);

                // Find current theme based on colors or localStorage
                const storedTheme = localStorage.getItem('current_theme') || 'black';
                const mappedTheme = LEGACY_THEME_MAP[storedTheme] || storedTheme;
                const currentTheme = THEME_TEMPLATES.find(template => template.id === mappedTheme) ||
                    THEME_TEMPLATES.find(template =>
                        template.home.home_theme_primary === merged.home_theme_primary &&
                        template.home.home_theme_accent === merged.home_theme_accent
                    );

                if (currentTheme) {
                    setSelectedTheme(currentTheme.id);
                    // Apply theme to DOM
                    const r = document.documentElement;
                    r.setAttribute('data-theme', currentTheme.id);
                    const homeSection = r.querySelector('[data-section="home"]');
                    const adminSection = r.querySelector('[data-section="admin"]');
                    if (homeSection) homeSection.setAttribute('data-theme', currentTheme.id);
                    if (adminSection) adminSection.setAttribute('data-theme', currentTheme.id);
                }
            } catch {
                setS(DEFAULTS);
            } finally {
                setLoading(false);
            }
        })();
    }, []);

    const applyTheme = async (themeId: string) => {
        const theme = THEME_TEMPLATES.find(t => t.id === themeId);
        if (!theme) return;

        const updatedSettings = {
            ...s,
            ...theme.home,
            ...theme.admin
        };

        try {
            await API.put("/settings", updatedSettings);
            setS(updatedSettings);
            setSelectedTheme(themeId);

            // Apply CSS variables immediately
            const r = document.documentElement;
            r.setAttribute('data-theme', themeId);

            // Update current theme variables based on section
            const homeSection = r.querySelector('[data-section="home"]');
            const adminSection = r.querySelector('[data-section="admin"]');

            if (homeSection) {
                homeSection.setAttribute('data-theme', themeId);
            }
            if (adminSection) {
                adminSection.setAttribute('data-theme', themeId);
            }

            // Update localStorage
            Object.entries(updatedSettings).forEach(([key, value]) => {
                if (key === "social_links") {
                    localStorage.setItem(key, JSON.stringify(value));
                } else {
                    localStorage.setItem(key, String(value));
                }
            });

            // Store current theme for both sections
            localStorage.setItem('current_theme', themeId);
            localStorage.setItem('current_home_theme', themeId);
            localStorage.setItem('current_admin_theme', themeId);

            // Notify other components in this tab
            window.dispatchEvent(new Event('settingsUpdated'));

            setSaved(true);
            setTimeout(() => setSaved(false), 1800);
        } catch (err: any) {
            alert("Error applying theme: " + (err?.response?.data?.message || err.message));
        }
    };

    if (loading) return <div style={{ color: "var(--current-text)" }}>Loading settings...</div>;

    return (
        <div style={{ maxWidth: 1000, margin: "0 auto", padding: "20px" }}>
            {/* Header */}
            <div style={{ marginBottom: 32 }}>
                <button
                    onClick={() => navigate("/admin/settings")}
                    style={{
                        ...backButton,
                        color: "var(--current-text-secondary)",
                        border: `1px solid var(--current-card-border)`
                    }}
                >
                    <ArrowLeft size={16} />
                    Back to Settings
                </button>
                <h1 style={{
                    fontSize: 28,
                    margin: "16px 0 8px 0",
                    fontWeight: 600,
                    color: "var(--current-text)"
                }}>
                    Appearance & Themes
                </h1>
                <p style={{
                    color: "var(--current-text-secondary)",
                    fontSize: 14,
                    margin: 0
                }}>
                    Choose a theme to customize your store's visual design
                </p>
            </div>

            {saved && (
                <div style={{
                    ...successMessage,
                    background: "rgba(34,197,94,0.1)",
                    border: "1px solid rgba(34,197,94,0.3)",
                    color: "#22c55e"
                }}>
                    ✅ Theme applied successfully.
                </div>
            )}

            {/* Theme Selection */}
            <div style={{ ...settingCard, background: "var(--current-card-bg)", border: `1px solid var(--current-card-border)` }}>
                <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 24 }}>
                    <Palette size={20} color="var(--current-accent)" />
                    <h3 style={{ ...sectionTitle, margin: 0, color: "var(--current-text)" }}>Choose Theme</h3>
                </div>
                <p style={{
                    color: "var(--current-text-secondary)",
                    fontSize: 14,
                    marginBottom: 24,
                    lineHeight: 1.5
                }}>
                    Select a theme to apply coordinated colors across your entire store. Each theme includes optimized colors for both your storefront and admin panel.
                </p>

                <div style={{
                    display: "grid",
                    gridTemplateColumns: "repeat(auto-fit, minmax(280px, 1fr))",
                    gap: 20
                }}>
                    {THEME_TEMPLATES.filter(theme => theme.id === 'black' || theme.id === 'light').map((theme) => (
                        <button
                            key={theme.id}
                            onClick={() => applyTheme(theme.id)}
                            style={{
                                ...themeCard,
                                background: "var(--current-card-bg)",
                                border: selectedTheme === theme.id
                                    ? `2px solid var(--current-accent)`
                                    : `1px solid var(--current-card-border)`,
                                cursor: "pointer",
                                transition: "all 0.2s ease"
                            }}
                            onMouseEnter={(e) => {
                                if (selectedTheme !== theme.id) {
                                    e.currentTarget.style.transform = "translateY(-2px)";
                                    e.currentTarget.style.boxShadow = "0 12px 24px rgba(0,0,0,0.15)";
                                }
                            }}
                            onMouseLeave={(e) => {
                                if (selectedTheme !== theme.id) {
                                    e.currentTarget.style.transform = "translateY(0)";
                                    e.currentTarget.style.boxShadow = "0 4px 12px rgba(0,0,0,0.08)";
                                }
                            }}
                        >
                            {/* Theme Preview */}
                            <div style={{
                                height: 80,
                                borderRadius: 8,
                                background: `linear-gradient(135deg, ${theme.preview.background} 0%, ${theme.preview.surface} 100%)`,
                                border: `1px solid ${theme.preview.primary}20`,
                                marginBottom: 16,
                                position: "relative",
                                overflow: "hidden"
                            }}>
                                {/* Mock UI Elements */}
                                <div style={{
                                    position: "absolute",
                                    top: 8,
                                    left: 8,
                                    right: 8,
                                    height: 6,
                                    background: theme.preview.primary,
                                    borderRadius: 3,
                                    opacity: 0.8
                                }} />
                                <div style={{
                                    position: "absolute",
                                    bottom: 8,
                                    left: 8,
                                    width: 40,
                                    height: 16,
                                    background: theme.preview.accent,
                                    borderRadius: 8
                                }} />
                                <div style={{
                                    position: "absolute",
                                    bottom: 8,
                                    right: 8,
                                    width: 60,
                                    height: 16,
                                    background: theme.preview.surface,
                                    border: `1px solid ${theme.preview.primary}30`,
                                    borderRadius: 8
                                }} />
                            </div>

                            {/* Theme Info */}
                            <div>
                                <h4 style={{
                                    margin: "0 0 8px 0",
                                    fontSize: 16,
                                    fontWeight: 600,
                                    color: "var(--current-text)"
                                }}>
                                    {theme.name}
                                </h4>
                                <p style={{
                                    margin: 0,
                                    fontSize: 13,
                                    color: "var(--current-text-secondary)",
                                    lineHeight: 1.4
                                }}>
                                    {theme.description}
                                </p>
                                {selectedTheme === theme.id && (
                                    <div style={{
                                        marginTop: 12,
                                        padding: "4px 8px",
                                        background: "var(--current-accent)",
                                        color: "var(--current-text)",
                                        borderRadius: 4,
                                        fontSize: 12,
                                        fontWeight: 500,
                                        textAlign: "center"
                                    }}>
                                        Active Theme
                                    </div>
                                )}
                            </div>
                        </button>
                    ))}
                </div>
            </div>
        </div>
    );
};

const backButton: React.CSSProperties = {
    display: "inline-flex",
    alignItems: "center",
    gap: 8,
    padding: "8px 16px",
    borderRadius: 8,
    background: "transparent",
    border: "1px solid transparent",
    cursor: "pointer",
    fontSize: 14,
    fontWeight: 500,
    transition: "all 0.2s ease",
    marginBottom: 8
};

const settingCard: React.CSSProperties = {
    padding: 24,
    borderRadius: 12,
    boxShadow: "0 4px 12px rgba(0,0,0,0.08)"
};

const sectionTitle: React.CSSProperties = {
    fontSize: 18,
    fontWeight: 600,
    margin: "0 0 20px 0",
    paddingBottom: 12,
    borderBottom: "1px solid var(--current-card-border)"
};

const themeCard: React.CSSProperties = {
    padding: 20,
    borderRadius: 12,
    boxShadow: "0 4px 12px rgba(0,0,0,0.08)",
    transition: "all 0.2s ease",
    textAlign: "left"
};

const successMessage: React.CSSProperties = {
    padding: 16,
    borderRadius: 8,
    marginBottom: 24,
    fontWeight: 500,
    textAlign: "center"
};

export default AppearanceSettings;